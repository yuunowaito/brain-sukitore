<div class="navbar bg-base-100 shadow-sm">
  <div class="navbar-start">
    <%= link_to root_path, class: "btn btn-ghost" do %>
      <span class="text-xl font-bold">脳のスキトレ</span>
    <% end %>
  </div>

  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1">
      <li><%= link_to "ゲームを選ぶ", "#" %></li>
      <li><%= link_to "スコア履歴", "#" %></li>
      <li><%= link_to "使い方", "#" %></li>
    </ul>
  </div>

  <div class="navbar-end">
    <% if user_signed_in? %>
      <%= link_to "ログアウト", destroy_user_session_path, data: { turbo_method: :delete }, class: "btn btn-ghost" %>
    <% else %>
      <%= link_to "ログイン", new_user_session_path, class: "btn btn-ghost" %>
      <%= link_to "新規登録", new_user_registration_path, class: "btn btn-primary" %>
    <% end %>
  </div>
</div>