<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "脳のスキトレ" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= display_meta_tags(default_meta_tags) %>

    <%= yield :head %>

    <link rel="manifest" href="/manifest.json">
    <%= favicon_link_tag "favicon/favicon.ico" %>
    <link rel="icon" type="image/png" sizes="32x32" href="<%= asset_path('favicon/favicon-32x32.png') %>">
    <link rel="icon" type="image/png" sizes="16x16" href="<%= asset_path('favicon/favicon-16x16.png') %>">
    <link rel="apple-touch-icon" href="<%= asset_path('favicon/apple-touch-icon.png') %>">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <%= render 'layouts/header' %>
    <% if notice %>
      <div role="alert" class="alert alert-success alert-soft">
        <span><%= notice %></span>
      </div>
    <% end %>
    <% if alert %>
      <div role="alert" class="alert alert-error alert-soft">
        <span><%= alert %></span>
      </div>
    <% end %>
    <%= yield %>
    <%= render 'layouts/footer' %>
  </body>
</html>
